# Import Libraries
import pandas as pd
import numpy as np
from sklearn.preprocessing import MinMaxScaler, StandardScaler, LabelEncoder


# Upload dataset in Colab and give file path
diabetes = pd.read_csv("Diabetes.csv")
adult = pd.read_csv("adult.csv")

print("Diabetes Dataset")
print(diabetes.head())

print("Adult Dataset")
print(adult.head())

print("Column Information (Diabetes)")
print(diabetes.info())

print("Column Information (Adult)")
print(adult.info())

print("Statistical Summary - Diabetes")
print(diabetes.describe())

print("Statistical Summary - Adult")
print(adult.describe())

print("Missing Values in Diabetes")
print(diabetes.isnull().sum())

print("Missing Values in Adult")
print(adult.isnull().sum())

# Handling Missing Values
diabetes.fillna(diabetes.mean(numeric_only=True), inplace=True)
adult.ffill(inplace=True) # Changed from adult.fillna(method='ffill', inplace=True) to address FutureWarning

label_encoder = LabelEncoder()

for column in adult.select_dtypes(include=['object']).columns:
    adult[column] = label_encoder.fit_transform(adult[column])

def remove_outliers(df):
    # Select only numerical columns for quantile calculation
    numeric_df = df.select_dtypes(include=np.number)

    Q1 = numeric_df.quantile(0.25)
    Q3 = numeric_df.quantile(0.75)
    IQR = Q3 - Q1

    # Create a boolean mask for outliers in numeric columns
    outlier_mask = ((numeric_df < (Q1 - 1.5 * IQR)) | (numeric_df > (Q3 + 1.5 * IQR))).any(axis=1)

    # Return the original DataFrame with outlier rows removed
    return df[~outlier_mask]

diabetes = remove_outliers(diabetes)

# Drop non-numeric columns from diabetes before scaling
diabetes_numeric = diabetes.select_dtypes(include=np.number)

minmax = MinMaxScaler()

diabetes_scaled = minmax.fit_transform(diabetes_numeric)

print("Min-Max Scaled Diabetes Data")
print(diabetes_scaled[:5])

scaler = StandardScaler()

diabetes_standard = scaler.fit_transform(diabetes_numeric)

print("Standard Scaled Diabetes Data")
print(diabetes_standard[:5])

print("Data Preprocessing Completed Successfully")
